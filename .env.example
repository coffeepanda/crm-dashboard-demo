# AetherGraph workspace
AETHERGRAPH_WORKSPACE=./aethergraph_workspace

# Default LLM profile used by context.llm()
AETHERGRAPH_LLM__ENABLED=true
AETHERGRAPH_LLM__DEFAULT__PROVIDER=openai
AETHERGRAPH_LLM__DEFAULT__MODEL=gpt-5o-nano
AETHERGRAPH_LLM__DEFAULT__BASE_URL=https://api.openai.com/v1
AETHERGRAPH_LLM__DEFAULT__TIMEOUT=60
AETHERGRAPH_LLM__DEFAULT__API_KEY=replace-with-your-api-key

# Optional embedding model for AetherGraph services that need embeddings.
# This demo does not currently use embeddings directly.
AETHERGRAPH_LLM__DEFAULT__EMBED_MODEL=text-embedding-3-small

# Provider swaps:
# - Anthropic: set PROVIDER=anthropic, MODEL=<claude-model>, API_KEY=<anthropic-key>
# - DeepSeek: set PROVIDER=deepseek, MODEL=<deepseek-model>, BASE_URL=https://api.deepseek.com, API_KEY=<deepseek-key>
